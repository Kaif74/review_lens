# Copy this file to `.env` and fill in the values you want to use locally.

# Preferred NVIDIA-compatible setup
NVIDIA_API_KEY=your_nvidia_api_key_here
REVIEW_SCRAPER_MODEL=deepseek-ai/deepseek-v3.1
REVIEW_SCRAPER_BASE_URL=https://integrate.api.nvidia.com/v1
REVIEW_SCRAPER_API_KEY_ENV=NVIDIA_API_KEY

# Optional OpenAI-compatible fallback
# OPENAI_API_KEY=your_openai_api_key_here

# Optional app defaults
REVIEW_SCRAPER_TOKENIZER_MODEL=gpt-4o-mini
REVIEW_SCRAPER_REQUEST_TIMEOUT=30

# Optional provider-specific extra_body JSON
# REVIEW_SCRAPER_EXTRA_BODY_JSON={"chat_template_kwargs":{"thinking":true}}
